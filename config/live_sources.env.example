# Demand-to-MVP Radar live-source credentials.
# Copy values into an ignored env file on the VPS, for example:
# /etc/demand-mvp-radar.env or /etc/telegram-research-agent.env

# Strong search-intent layer.
SERPAPI_API_KEY=

# Higher quota for public GitHub search. Fine-grained PAT with public read is enough.
GITHUB_TOKEN=

# Creator/tutorial demand layer.
YOUTUBE_API_KEY=

# Competitor/launch layer. Check Product Hunt API commercial-use rules before product use.
PRODUCT_HUNT_TOKEN=

# Community pain layer. Use a read-only Reddit app/user-agent and allowlisted subreddits.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Demand-to-MVP-Radar/0.1 by YOUR_REDDIT_USERNAME

# Optional quota helper for Stack Exchange.
STACK_EXCHANGE_KEY=
